# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

HTTP_ADDR=127.0.0.1:8090

# LLM (eino) — required
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL_NAME=gpt-4o-mini

# qui API — required
QUI_BASE_URL=http://localhost:8080
# QUI_API_KEY=  # optional, set if your qui instance requires auth
QUI_INSTANCE_ID=1

# TMDb — required
TMDB_API_KEY=

# Brave Search API — optional, enables Wikipedia fallback when TMDb finds nothing
# BRAVE_API_KEY=

# Anime list API — required
ANIMELIST_BASE_URL=http://localhost:3000
ANIMELIST_USERNAME=
ANIMELIST_PASSWORD=

# rsync config - required
RSYNC_HOST=192.168.1.100
RSYNC_MODULE=media
RSYNC_USER=
RSYNC_PASSWORD_FILE=/path/to/password.txt
RSYNC_PORT=873
RSYNC_BINARY=rsync
# Folder inside the rsync module where anime is stored (e.g. rsync://.../media/anime/)
NAS_ANIME_BASE_PATH=anime

# Webhook notification URL — optional
# WEBHOOK_URL=https://...
