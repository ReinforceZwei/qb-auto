# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# LLM (eino) — required
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...

# qui API — required
QUI_BASE_URL=http://localhost:8080
# QUI_API_KEY=  # optional, set if your qui instance requires auth

# TMDb — required
TMDB_API_KEY=

# Anime list API — required
ANIMELIST_BASE_URL=http://localhost:3000
# ANIMELIST_API_KEY=  # optional, set if your anime-list instance requires auth

# rsync / NAS destination — required
# Format: [user@]host:/path  or just a local path
NAS_DEST_PATH=user@nas:/volume1/anime

# Webhook notification URL — optional
# WEBHOOK_URL=https://...
